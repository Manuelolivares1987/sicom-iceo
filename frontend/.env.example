# ===========================================================================
# SICOM-ICEO — Variables de entorno de ejemplo
# ===========================================================================
# Copie este archivo como `.env.local` y rellene los valores reales.
# NUNCA versione `.env.local` ni archivos con valores reales.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Supabase (obligatorias en runtime cliente)
# ---------------------------------------------------------------------------
# Las llaves NEXT_PUBLIC_* se exponen al navegador. La anon key está diseñada
# para ser pública y se complementa con Row Level Security (RLS) en Postgres.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# ---------------------------------------------------------------------------
# Resend — envío del reporte de flota por correo (solo servidor)
# ---------------------------------------------------------------------------
# Se usan SOLO en la API route /api/reporte-flota/enviar (servidor), nunca en
# el navegador. En producción, configúralas en Netlify → Site settings → Env.
#   1. Crea una cuenta gratis en https://resend.com (3.000 correos/mes).
#   2. API Keys → Create → copia la clave (empieza con "re_").
#   3. Para mejor entrega, verifica un dominio remitente en Resend y usa una
#      dirección de ese dominio en RESEND_FROM. Sin dominio propio puedes
#      probar con el remitente por defecto (onboarding@resend.dev).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Reporte Flota Pillado <reportes@tudominio.cl>

# ---------------------------------------------------------------------------
# Correo SMTP (Gmail gratuito) — No Conformidades + Sugerencias (solo servidor)
# ---------------------------------------------------------------------------
# Para enviar desde un Gmail gratis:
#   1. Crea (o usa) una cuenta Gmail, ej. taller.pillado@gmail.com
#   2. Activa la verificación en 2 pasos en esa cuenta.
#   3. Google Account -> Seguridad -> Contraseñas de aplicaciones -> genera una
#      (16 caracteres). Esa es SMTP_PASS (NO la contraseña normal).
#   4. Configura estas variables en Netlify -> Site settings -> Environment.
SMTP_USER=taller.pillado@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx
# Opcionales (defaults: smtp.gmail.com / 465 / "PILLADO ICEO <SMTP_USER>")
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
MAIL_FROM=PILLADO ICEO <taller.pillado@gmail.com>

# Destinatarios (separados por coma) de los avisos de No Conformidades.
NC_EMAIL_TO=jefe.taller@empresa.cl, supervisor@empresa.cl, molivares.codoceo@gmail.com
# Destinatario de las sugerencias (la ampolleta). Si falta, usa NC_EMAIL_TO.
SUGERENCIAS_EMAIL_TO=molivares.codoceo@gmail.com

# ---------------------------------------------------------------------------
# Cron del digest de No Conformidades (solo servidor)
# ---------------------------------------------------------------------------
# Secreto compartido entre el cron de la BD (pg_cron -> net.http_post) y la API
# /api/notificaciones/nc-digest. Debe coincidir con el header x-cron-secret del
# comando del cron. Genera un valor aleatorio largo.
CRON_SECRET=pon-un-secreto-aleatorio-largo
# Service role de Supabase — SOLO para la API del digest (server-side). Permite
# leer/actualizar no_conformidades saltando RLS desde el cron (sin usuario).
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ---------------------------------------------------------------------------
# NUNCA poner aquí (en el navegador / con prefijo NEXT_PUBLIC_)
# ---------------------------------------------------------------------------
# - SUPABASE_SERVICE_ROLE_KEY, SMTP_PASS, CRON_SECRET -> solo backend, jamás frontend.
# - Tokens de proveedores externos sin prefijo NEXT_PUBLIC_ se filtrarían si
#   accidentalmente se referencian desde código cliente.
